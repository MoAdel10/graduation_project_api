<%- include('../partials/header') %>
<div class="card">
    <div class="card-header">
        <h2 class="card-title">Property Listings</h2>
    </div>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Location</th>
                <th>Verified</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% properties.forEach(p => { %>
                <tr>
                    <td><%= p.property_id %></td>
                    <td><strong><%= p.property_name %></strong></td>
                    <td><%= p.location %></td>
                    <td>
                        <span class="badge <%= p.is_verified ? 'badge-green' : 'badge-red' %>">
                            <%= p.is_verified ? "Verified" : "Unverified" %>
                        </span>
                    </td>
                    <td>
                        <a href="/admin/properties/view/details/<%= p.property_id %>" class="btn btn-gold btn-sm">
                            View Details
                        </a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<%- include('../partials/footer') %>
