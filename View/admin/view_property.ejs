<%- include('../partials/header') %>

<style>
    .prop-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 2px solid var(--border);
    }
    .prop-header h2 { margin:0; font-size:22px; }
    .prop-header h2 span { color: var(--gold); }

    .inspect-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
    }
    @media (max-width: 900px) {
        .inspect-grid { grid-template-columns: 1fr; }
    }

    .inspect-section h3 {
        font-size: 16px;
        font-weight: 700;
        color: var(--dk);
        margin: 0 0 16px 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-table { width: 100%; border-collapse: collapse; }
    .info-table td {
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }
    .info-table .label {
        font-weight: 600;
        color: var(--muted);
        width: 130px;
    }

    .desc-box {
        background: #f8fafc;
        padding: 16px 20px;
        border-radius: 10px;
        border-left: 4px solid var(--gold);
        color: var(--text);
        line-height: 1.7;
        font-size: 14px;
        margin-top: 8px;
    }

    .image-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    .image-item {
        border-radius: 10px;
        overflow: hidden;
        aspect-ratio: 4/3;
        background: #e2e8f0;
        transition: transform .2s;
    }
    .image-item:hover {
        transform: scale(1.02);
        box-shadow: 0 4px 12px rgba(0,0,0,.12);
    }
    .image-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .doc-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        text-decoration: none;
        font-size: 14px;
        transition: all .2s;
    }
    .doc-link:hover {
        border-color: var(--gold);
        background: rgba(212,175,55,.04);
    }

    .action-bar {
        margin-top: 40px;
        padding-top: 24px;
        border-top: 2px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        align-items: center;
    }
</style>

<div class="card" style="padding:32px;">
    <div class="prop-header">
        <h2>Inspect: <span><%= property.property_name %></span></h2>
        <a href="/admin/verification/requests" class="btn btn-ghost btn-sm">← Back</a>
    </div>

    <div class="inspect-grid">
        <div class="inspect-section">
            <h3>📋 Basic Details</h3>
            <table class="info-table">
                <tr><td class="label">Location</td><td><%= property.location %></td></tr>
                <tr><td class="label">Price</td><td style="color:var(--gold); font-weight:700;">$<%= property.price_per_day %> / Night</td></tr>
                <tr><td class="label">Dimensions</td><td><%= property.size %> m²</td></tr>
                <tr><td class="label">Capacity</td><td><%= property.bedrooms_no %> Bedrooms &middot; <%= property.bathrooms_no %> Bathrooms</td></tr>
                <tr>
                    <td class="label">Verification</td>
                    <td>
                        <span class="badge <%= property.is_verified ? 'badge-green' : 'badge-red' %>">
                            <%= property.is_verified ? "Verified" : "Unverified" %>
                        </span>
                    </td>
                </tr>
            </table>

            <h3 style="margin-top:28px;">📝 Description</h3>
            <div class="desc-box"><%= property.property_desc %></div>

            <h3 style="margin-top:28px;">📎 Ownership Documents</h3>
            <div style="display:grid; gap:8px;">
                <% if (property.ownership_proofs) {
                    let proofs = typeof property.ownership_proofs === 'string' ? JSON.parse(property.ownership_proofs) : property.ownership_proofs;
                    proofs.forEach((proof, index) => { %>
                        <a href="/<%= proof %>" target="_blank" class="doc-link">
                            <span>📄</span>
                            <span>Verification Proof #<%= index + 1 %></span>
                            <span style="margin-left:auto; font-size:11px; color:var(--muted);">View ↗</span>
                        </a>
                <% })} else { %>
                    <p style="color:var(--danger); font-size:14px;">No documents provided.</p>
                <% } %>
            </div>
        </div>

        <div class="inspect-section">
            <h3>🖼️ Property Gallery</h3>
            <div class="image-grid">
                <% if (property.images) {
                    let imgs = typeof property.images === 'string' ? JSON.parse(property.images) : property.images;
                    imgs.forEach(img => { %>
                        <div class="image-item">
                            <img src="/<%= img %>" alt="Property View" loading="lazy">
                        </div>
                <% })} else { %>
                    <p style="color:var(--muted);">No images found.</p>
                <% } %>
            </div>
        </div>
    </div>

    <div class="action-bar">
        <% if (property.request_id) { %>
            <form action="/admin/verification/reject/<%= property.request_id %>" method="POST" style="display:flex; gap:8px; align-items:center;">
                <input type="text" name="reason" placeholder="Rejection reason..." style="width:220px; padding:8px 12px;">
                <button type="submit" class="btn btn-red">Reject</button>
            </form>
            <form action="/admin/verification/approve/<%= property.request_id %>" method="POST" style="margin:0;">
                <button type="submit" class="btn btn-gold">Approve Verification</button>
            </form>
        <% } else { %>
            <p style="color:var(--muted); font-style:italic; font-size:14px;">Viewing mode — No pending verification requests for this property.</p>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
