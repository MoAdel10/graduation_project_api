<%- include('../partials/header') %>
<div class="card">
    <h2 class="card-title">Admin Management</h2>
    <table>
        <thead>
            <tr><th>ID</th><th>Email</th><th>Role</th></tr>
        </thead>
        <tbody>
            <% admins.forEach(a => { %>
                <tr>
                    <td><%= a.admin_id %></td>
                    <td><%= a.email %></td>
                    <td><span class="badge badge-gold"><%= a.role %></span></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<%- include('../partials/footer') %>
