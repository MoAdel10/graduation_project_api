<%- include('../partials/header') %>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">Ownership Verification Requests</h2>
        <span class="badge badge-gold">Pending: <%= requests.length %></span>
    </div>

    <table>
        <thead>
            <tr>
                <th>Property ID</th>
                <th>Property Name</th>
                <th>Owner Name</th>
                <th>Document Link</th>
                <th>Request Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (requests.length > 0) { %>
                <% requests.forEach(req => { %>
                <tr>
                    <td><%= req.property_id %></td>
                    <td><strong><%= req.property_name %></strong></td>
                    <td><%= req.first_name %> <%= req.second_name %></td>
                    <td>
                        <a href="/admin/properties/view/<%= req.property_id %>" class="btn btn-ghost btn-sm">
                            Inspect Property
                        </a>
                    </td>
                    <td><%= new Date(req.created_at).toLocaleDateString() %></td>
                    <td>
                        <div class="actions">
                            <form action="/admin/verification/approve/<%= req.request_id %>" method="POST" style="margin:0;">
                                <button type="submit" class="btn btn-green btn-sm">Approve</button>
                            </form>
                            <form action="/admin/verification/reject/<%= req.request_id %>" method="POST" style="margin:0;">
                                <button type="submit" class="btn btn-red btn-sm">Reject</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" class="empty">No pending verification requests found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
