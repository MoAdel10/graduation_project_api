<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — Aqar Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #f1f5f9;
            display: flex;
            min-height: 100vh;
            color: #1e293b;
        }

        :root {
            --dk: #0F172A;
            --gold: #D4AF37;
            --gold-light: #FCD34D;
            --gold-hover: #b8942e;
            --bg: #f1f5f9;
            --card: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --border: #e2e8f0;
            --success: #10b981;
            --danger: #ef4444;
            --sidebar-w: 250px;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: var(--dk);
            color: #fff;
            position: fixed;
            inset: 0 auto 0 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 24px 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-brand h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--gold);
            letter-spacing: -.5px;
        }
        .sidebar-brand span {
            font-size: 12px;
            color: rgba(255,255,255,.4);
            margin-top: 2px;
            display: block;
        }

        .sidebar-nav {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .sidebar-nav a {
            color: rgba(255,255,255,.65);
            text-decoration: none;
            padding: 11px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar-nav a:hover {
            background: rgba(212,175,55,.12);
            color: var(--gold-light);
        }

        .sidebar-foot {
            padding: 16px 12px;
            border-top: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-foot a {
            color: rgba(255,255,255,.45);
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar-foot a:hover {
            background: rgba(239,68,68,.15);
            color: #fca5a5;
        }

        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 32px;
            min-height: 100vh;
        }
        .welcome { margin-bottom: 28px; }
        .welcome h1 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dk);
        }
        .welcome p {
            font-size: 14px;
            color: var(--muted);
            margin-top: 4px;
        }

        .card {
            background: var(--card);
            border-radius: 12px;
            padding: 28px;
            box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
            border: 1px solid var(--border);
            margin-bottom: 24px;
        }
        .card h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--dk);
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }
        table thead th {
            background: #f8fafc;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: var(--muted);
            border-bottom: 2px solid var(--border);
            text-align: left;
            white-space: nowrap;
        }
        table tbody td {
            padding: 14px 16px;
            font-size: 14px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }
        table tbody tr:hover { background: #f8fafc; }
        table tbody tr:last-child td { border-bottom: none; }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-gold  { background: rgba(212,175,55,.12); color: #8a731e; }
        .badge-green { background: #dcfce7; color: #166534; }
        .badge-red   { background: #fef2f2; color: #dc2626; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 18px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: all .2s;
            gap: 6px;
            font-family: inherit;
        }
        .btn-gold   { background: var(--gold); color: #0F172A; }
        .btn-gold:hover { background: var(--gold-hover); }
        .btn-red    { background: var(--danger); color: #fff; }
        .btn-red:hover { background: #dc2626; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-brand">
            <h2>🏠 Aqar</h2>
            <span>Property Admin</span>
        </div>
        <div class="sidebar-nav">
            <a href="/admin/dashboard?section=admins"><span>👥</span> Admins</a>
            <a href="/admin/dashboard?section=users"><span>👤</span> Users</a>
            <a href="/admin/dashboard?section=properties"><span>🏘️</span> Properties</a>
        </div>
        <div class="sidebar-foot">
            <a href="/admin/logout">🚪 Logout</a>
        </div>
    </div>
    <div class="main">
        <div class="welcome">
            <h1>Welcome, <%= admin.email %>!</h1>
            <p>Admin ID: <%= admin.admin_id %> &middot; Role: <%= admin.role %></p>
        </div>

        <div class="card">
            <% if (!section || section === 'admins' && admin.role == "super_admin") { %>
                <h2>Admins</h2>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Email</th><th>Role</th></tr>
                    </thead>
                    <tbody>
                        <% admins.forEach(adminItem => { %>
                        <tr>
                            <td><%= adminItem.admin_id %></td>
                            <td><%= adminItem.email %></td>
                            <td><span class="badge badge-gold"><%= adminItem.role %></span></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else if (section === 'users') { %>
                <h2>Users</h2>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Name</th><th>Email</th></tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.user_id %></td>
                            <td><%= user.first_name+" "+user.second_name %></td>
                            <td><%= user.email %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else if (section === 'properties') { %>
                <h2>Properties</h2>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Title</th><th>Location</th><th>Owner</th><th>Owner ID</th><th>Verified</th></tr>
                    </thead>
                    <tbody>
                        <% properties.forEach(property => { %>
                        <tr>
                            <td><%= property.property_id %></td>
                            <td><%= property.property_name %></td>
                            <td><%= property.location %></td>
                            <td><%= property.owner?property.owner:undefined%></td>
                            <td><%= property.owner_id?property.owner_id:undefined%></td>
                            <td>
                                <span class="badge <%= property.verified ? 'badge-green' : 'badge-red' %>">
                                    <%= property.verified ? "Verified" : "Unverified" %>
                                </span>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</body>
</html>
