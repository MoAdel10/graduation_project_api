<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel — Aqar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #f1f5f9;
            display: flex;
            min-height: 100vh;
            color: #1e293b;
        }

        :root {
            --dk: #0F172A;
            --gold: #D4AF37;
            --gold-light: #FCD34D;
            --gold-hover: #b8942e;
            --bg: #f1f5f9;
            --card: #ffffff;
            --text: #1e293b;
            --muted: #64748b;
            --border: #e2e8f0;
            --success: #10b981;
            --danger: #ef4444;
            --sidebar-w: 250px;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: var(--dk);
            color: #fff;
            position: fixed;
            inset: 0 auto 0 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 24px 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-brand h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--gold);
            letter-spacing: -.5px;
        }
        .sidebar-brand span {
            font-size: 12px;
            color: rgba(255,255,255,.4);
            margin-top: 2px;
            display: block;
        }

        .sidebar-nav {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .sidebar-nav a {
            color: rgba(255,255,255,.65);
            text-decoration: none;
            padding: 11px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar-nav a:hover {
            background: rgba(212,175,55,.12);
            color: var(--gold-light);
        }

        .sidebar-foot {
            padding: 16px 12px;
            border-top: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-foot a {
            color: rgba(255,255,255,.45);
            text-decoration: none;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar-foot a:hover {
            background: rgba(239,68,68,.15);
            color: #fca5a5;
        }

        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 32px;
            min-height: 100vh;
        }
        .welcome { margin-bottom: 28px; }
        .welcome h1 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dk);
        }
        .welcome p {
            font-size: 14px;
            color: var(--muted);
            margin-top: 4px;
        }

        .card {
            background: var(--card);
            border-radius: 12px;
            padding: 28px;
            box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
            border: 1px solid var(--border);
            margin-bottom: 24px;
        }
        .card-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--dk);
            margin-bottom: 20px;
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .card-header .card-title { margin-bottom: 0; }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }
        table thead th {
            background: #f8fafc;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: var(--muted);
            border-bottom: 2px solid var(--border);
            text-align: left;
            white-space: nowrap;
        }
        table tbody td {
            padding: 14px 16px;
            font-size: 14px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }
        table tbody tr:hover { background: #f8fafc; }
        table tbody tr:last-child td { border-bottom: none; }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-gold  { background: rgba(212,175,55,.12); color: #8a731e; }
        .badge-green { background: #dcfce7; color: #166534; }
        .badge-red   { background: #fef2f2; color: #dc2626; }
        .badge-gray  { background: #f1f5f9; color: #475569; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 18px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: all .2s;
            gap: 6px;
            font-family: inherit;
        }
        .btn-gold   { background: var(--gold); color: #0F172A; }
        .btn-gold:hover { background: var(--gold-hover); }
        .btn-green  { background: var(--success); color: #fff; }
        .btn-green:hover { background: #059669; }
        .btn-red    { background: var(--danger); color: #fff; }
        .btn-red:hover { background: #dc2626; }
        .btn-ghost  { background: transparent; border: 1.5px solid var(--border); color: var(--text); }
        .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }
        .btn-sm { padding: 5px 12px; font-size: 12px; border-radius: 6px; }

        input, textarea, select {
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            transition: all .2s;
            outline: none;
            background: #fff;
        }
        input:focus, textarea:focus, select:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,175,55,.15);
        }

        .actions { display: flex; gap: 8px; align-items: center; }
        .empty { text-align: center; padding: 40px 20px; color: var(--muted); }

        .flex { display: flex; }
        .gap-2 { gap: 8px; }
        .gap-3 { gap: 12px; }
        .items-center { align-items: center; }
        .justify-between { justify-content: space-between; }
        .mt-2 { margin-top: 8px; }
        .mt-4 { margin-top: 16px; }
        .mb-2 { margin-bottom: 8px; }
        .mb-4 { margin-bottom: 16px; }
        .w-full { width: 100%; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-brand">
            <h2>🏠 Aqar</h2>
            <span>Property Admin</span>
        </div>
        <div class="sidebar-nav">
            <a href="/admin/admins"><span>👥</span> Admins</a>
            <a href="/admin/users"><span>👤</span> Users</a>
            <a href="/admin/properties"><span>🏘️</span> Properties</a>
            <a href="/admin/verification/requests"><span>✅</span> Verifications</a>
            <a href="/admin/refund-requests"><span>↩️</span> Refunds</a>
        </div>
        <div class="sidebar-foot">
            <a href="/admin/logout">🚪 Logout</a>
        </div>
    </div>
    <div class="main">
        <div class="welcome">
            <h1>Welcome, <%= admin.email %>!</h1>
            <% if (typeof admin.role !== 'undefined') { %><p>Role: <%= admin.role %></p><% } %>
        </div>
